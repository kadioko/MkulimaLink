{
  "name": "mkulimalink",
  "version": "2.0.0",
  "description": "AI-powered agriculture super-app for East Africa",
  "main": "index-final.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node index-final.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon backend/server.js",
    "client": "npm start --prefix frontend",
    "build": "npm run build --prefix frontend",
    "test": "jest",
    "test:frontend": "npm test --prefix frontend",
    "test:mobile": "npm test --prefix mobile/MkulimaLink",
    "lint": "npm run lint --prefix mobile/MkulimaLink",
    "audit:all": "npm audit --audit-level=moderate && npm audit --audit-level=moderate --prefix frontend && npm audit --audit-level=moderate --prefix mobile/MkulimaLink",
    "install-all": "npm install && npm install --prefix frontend && npm install --prefix mobile/MkulimaLink",
    "seed": "node seedData.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1065.0",
    "@sentry/node": "^10.57.0",
    "@sentry/profiling-node": "^10.57.0",
    "axios": "^1.17.0",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "compression": "^1.8.1",
    "compromise": "^14.15.1",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "fluent-ffmpeg": "^2.1.3",
    "geolib": "^3.3.14",
    "handlebars": "^4.7.9",
    "helmet": "^7.2.0",
    "js-yaml": "^4.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.0",
    "morgan": "^1.11.0",
    "multer": "^2.1.1",
    "natural": "^8.1.1",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.11",
    "redis": "^6.0.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.2",
    "web3": "^4.16.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "jest": "^30.4.2",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  },
  "keywords": [
    "agriculture",
    "marketplace",
    "farming",
    "tanzania"
  ],
  "author": "MkulimaLink Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kadioko/MkulimaLink.git"
  },
  "homepage": "https://mkulimalink.vercel.app"
}
