# MkulimaLink Frontend Environment Variables
# Copy this file to .env and fill in your values

# API Configuration
REACT_APP_API_URL=https://api.mkulimalink.com
# For local development:
# REACT_APP_API_URL=http://localhost:5000

# WebSocket Configuration  
REACT_APP_WS_URL=wss://api.mkulimalink.com
# For local development:
# REACT_APP_WS_URL=ws://localhost:5000

# Maps Configuration (Get from Mapbox or Google Cloud)
REACT_APP_MAPS_API_KEY=your_maps_api_key_here

# Optional: Analytics
# REACT_APP_ANALYTICS_ID=your_analytics_id
# REACT_APP_SENTRY_DSN=your_sentry_dsn

# Build Configuration
# GENERATE_SOURCEMAP=false
# REACT_APP_VERSION=$npm_package_version
