# MkulimaLink Frontend Environment Variables
# Copy this file to .env and fill in your values.

# API Configuration
VITE_API_URL=https://api.mkulimalink.com
# For local development:
# VITE_API_URL=http://localhost:5000

# WebSocket Configuration
VITE_WS_URL=wss://api.mkulimalink.com/ws
VITE_CHAT_WS_URL=wss://api.mkulimalink.com/chat
VITE_AUCTION_WS_URL=wss://api.mkulimalink.com/auction
# For local development:
# VITE_WS_URL=ws://localhost:5000/ws

# Optional: Push Notifications and Analytics
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key
VITE_ANALYTICS_KEY=your_analytics_key

# Legacy REACT_APP_* names are still read by the app as a migration fallback,
# but new deployments should use VITE_* names.
